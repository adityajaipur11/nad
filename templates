<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Destro — Threat Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    :root{
      --bg:#f4f6fb;--surface:#fff;--surface2:#f8fafc;--border:#e8edf5;
      --indigo:#6366f1;--indigo-dark:#4f46e5;--indigo-light:#eef2ff;--indigo-mid:#818cf8;
      --purple:#a855f7;
      --red:#ef4444;--red-light:#fef2f2;
      --green:#10b981;--green-light:#f0fdf4;
      --amber:#f59e0b;--amber-light:#fffbeb;
      --orange:#f97316;--orange-light:#fff7ed;
      --text:#1e293b;--text2:#475569;--muted:#94a3b8;
      --sans:'Inter',sans-serif;--mono:'JetBrains Mono',monospace;
      --shadow:0 1px 3px rgba(0,0,0,0.06),0 1px 2px rgba(0,0,0,0.04);
      --shadow-md:0 4px 12px rgba(0,0,0,0.08),0 2px 4px rgba(0,0,0,0.04);
    }
    body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;display:flex;flex-direction:column;}

    /* TOPBAR */
    .topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 20px;height:56px;
            display:flex;align-items:center;justify-content:space-between;box-shadow:var(--shadow);
            position:sticky;top:0;z-index:100;}
    .tb-left{display:flex;align-items:center;gap:10px;}
    .tb-logo{width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,var(--indigo),var(--purple));
             display:flex;align-items:center;justify-content:center;font-size:15px;
             box-shadow:0 2px 8px rgba(99,102,241,0.35);}
    .tb-name{font-size:16px;font-weight:700;letter-spacing:-0.3px;}
    .tb-badge{font-size:10px;font-weight:600;font-family:var(--mono);color:var(--indigo);background:var(--indigo-light);
              border:1px solid #c7d2fe;padding:2px 8px;border-radius:20px;display:flex;align-items:center;gap:4px;}
    .live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(0.8);}}
    .tb-right{display:flex;align-items:center;gap:8px;}
    #clock{font-size:12px;font-family:var(--mono);color:var(--muted);background:var(--surface2);
           padding:4px 10px;border-radius:6px;border:1px solid var(--border);}
    .alert-pill{display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;
                color:var(--red);background:var(--red-light);border:1px solid #fecaca;
                padding:4px 10px;border-radius:20px;}
    .alert-pill.hidden{display:none;}
    .ai-pill{display:flex;align-items:center;gap:5px;font-size:10px;font-weight:600;font-family:var(--mono);
             padding:4px 10px;border-radius:20px;cursor:pointer;border:1px solid;}
    .ai-pill.on{color:#059669;background:var(--green-light);border-color:#bbf7d0;}
    .ai-pill.off{color:var(--muted);background:var(--surface2);border-color:var(--border);}
    .ai-pill:hover{border-color:var(--indigo-mid);color:var(--indigo);background:var(--indigo-light);}
    .icon-btn{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;
              font-size:15px;cursor:pointer;background:transparent;border:1px solid var(--border);color:var(--muted);
              transition:all 0.15s;}
    .icon-btn:hover{background:var(--indigo-light);color:var(--indigo);border-color:var(--indigo-mid);}
    .home-link{text-decoration:none;}

    /* LAYOUT */
    .body-wrap{display:flex;flex:1;}
    .sidebar{width:56px;background:var(--surface);border-right:1px solid var(--border);padding:14px 0;
             display:flex;flex-direction:column;align-items:center;gap:4px;}
    .sb-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;
             font-size:17px;cursor:pointer;color:var(--muted);transition:all 0.2s;position:relative;}
    .sb-icon:hover{background:var(--indigo-light);color:var(--indigo);}
    .sb-icon.active{background:var(--indigo-light);color:var(--indigo);}
    .sb-icon.active::before{content:'';position:absolute;left:-1px;top:50%;transform:translateY(-50%);
                             width:3px;height:20px;background:var(--indigo);border-radius:0 3px 3px 0;}
    .sb-sep{width:24px;height:1px;background:var(--border);margin:6px 0;}
    .sb-icon[title]:hover::after{content:attr(title);position:absolute;left:50px;background:var(--text);
      color:#fff;font-size:10px;padding:3px 8px;border-radius:6px;white-space:nowrap;pointer-events:none;z-index:200;}

    .main{flex:1;padding:18px 22px;overflow:auto;}
    section{scroll-margin-top:70px;}

    /* HEADER */
    .main-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px;}
    .main-title{font-size:17px;font-weight:700;}
    .main-sub{font-size:11px;font-family:var(--mono);color:var(--muted);margin-top:3px;}
    .header-btns{display:flex;gap:8px;flex-wrap:wrap;}
    .btn{padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;
         transition:all 0.18s;border:1.5px solid;display:flex;align-items:center;gap:5px;}
    .btn:active{transform:scale(0.97);}
    .btn-scan{background:var(--indigo);border-color:var(--indigo);color:#fff;box-shadow:0 2px 8px rgba(99,102,241,0.3);}
    .btn-scan:hover{background:var(--indigo-dark);}
    .btn-scan:disabled{opacity:0.6;cursor:not-allowed;}
    .btn-attack{background:var(--surface);border-color:var(--border);color:var(--text2);}
    .btn-attack:hover{border-color:var(--red);color:var(--red);background:var(--red-light);}
    .btn-attack.active{background:var(--red-light);border-color:var(--red);color:var(--red);}

    /* BANNERS */
    .banner{display:none;border-radius:10px;padding:9px 14px;margin-bottom:12px;font-size:12px;
            align-items:center;gap:10px;animation:slideIn 0.25s ease;}
    .banner.visible{display:flex;}
    .banner-attack{background:#fff7ed;border:1px solid #fed7aa;color:#c2410c;}
    .banner-inject{background:var(--red-light);border:1px solid #fecaca;color:#dc2626;}
    .banner-error{background:var(--amber-light);border:1px solid #fde68a;color:#92400e;}
    .banner-nokey{background:var(--indigo-light);border:1px solid #c7d2fe;color:#4338ca;}
    .banner-payload{font-size:10px;font-family:var(--mono);color:#b91c1c;margin-top:3px;word-break:break-all;}
    @keyframes slideIn{from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);}}

    /* STAT CARDS */
    .stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px;}
    @media(max-width:900px){.stat-row{grid-template-columns:repeat(2,1fr);}}
    .stat-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;
               padding:14px 16px;box-shadow:var(--shadow);}
    .sc-label{font-size:10px;font-family:var(--mono);color:var(--muted);font-weight:500;margin-bottom:6px;}
    .sc-value{font-size:26px;font-weight:800;font-family:var(--mono);line-height:1;}
    .sc-sub{font-size:10px;color:var(--muted);margin-top:4px;}
    .sc-value.red{color:var(--red);}
    .sc-value.amber{color:var(--amber);}
    .sc-value.green{color:var(--green);}
    .sc-value.indigo{color:var(--indigo);}

    /* CHARTS */
    .charts-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:14px;}
    @media(max-width:1024px){.charts-row{grid-template-columns:1fr 1fr;}}
    @media(max-width:640px){.charts-row{grid-template-columns:1fr;}.sidebar{display:none;}}
    .chart-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px;box-shadow:var(--shadow);}
    .chart-title{font-size:12px;font-weight:600;margin-bottom:2px;}
    .chart-sub{font-size:10px;font-family:var(--mono);color:var(--muted);margin-bottom:10px;}
    .chart-wrap{position:relative;}
    .chart-wrap.donut{height:150px;display:flex;align-items:center;justify-content:center;}
    .chart-wrap.line,.chart-wrap.bar{height:130px;}
    .donut-center{position:absolute;text-align:center;pointer-events:none;}
    .donut-num{font-size:20px;font-weight:800;font-family:var(--mono);}
    .donut-label{font-size:10px;color:var(--muted);}

    /* PANELS */
    .content-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
    @media(max-width:768px){.content-row{grid-template-columns:1fr;}}
    .panel{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px;box-shadow:var(--shadow);}
    .panel-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
    .panel-title{font-size:13px;font-weight:600;}
    .panel-meta{font-size:10px;font-family:var(--mono);color:var(--muted);}

    /* SEVERITY BADGES */
    .sev{font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;font-family:var(--mono);white-space:nowrap;}
    .sev-CRITICAL{background:#fee2e2;color:#b91c1c;border:1px solid #fecaca;}
    .sev-HIGH    {background:#fff7ed;color:#c2410c;border:1px solid #fed7aa;}
    .sev-MEDIUM  {background:#fffbeb;color:#b45309;border:1px solid #fde68a;}
    .sev-LOW     {background:var(--green-light);color:#166534;border:1px solid #bbf7d0;}
    .sev-NONE    {background:var(--surface2);color:var(--muted);border:1px solid var(--border);}

    /* HEADLINES */
    .headline-list{display:flex;flex-direction:column;gap:5px;max-height:280px;overflow-y:auto;}
    .headline-list::-webkit-scrollbar{width:4px;}
    .headline-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
    .hl-row{display:flex;align-items:flex-start;gap:8px;padding:7px 10px;background:var(--surface2);
            border-radius:8px;border:1px solid var(--border);transition:all 0.15s;cursor:default;}
    .hl-row.threat-row{background:var(--red-light);border-color:#fecaca;}
    .hl-row.threat-row.HIGH{background:#fff7ed;border-color:#fed7aa;}
    .hl-row.threat-row.MEDIUM{background:var(--amber-light);border-color:#fde68a;}
    .hl-row.threat-row.LOW{background:var(--green-light);border-color:#bbf7d0;}
    .sev-bar{width:3px;min-height:30px;border-radius:2px;flex-shrink:0;margin-top:2px;}
    .sev-bar.CRITICAL,.sev-bar.HIGH{background:var(--red);}
    .sev-bar.MEDIUM{background:var(--amber);}
    .sev-bar.LOW{background:var(--green);}
    .sev-bar.NONE{background:var(--border);}
    .hl-body{flex:1;min-width:0;}
    .hl-src{font-size:10px;font-family:var(--mono);color:var(--muted);}
    .hl-text{font-size:11px;margin-top:2px;line-height:1.4;}
    .hl-cat{font-size:9px;font-family:var(--mono);color:var(--indigo-mid);margin-top:2px;}

    /* THREAT RESPONSE PANEL */
    .threat-panel{background:var(--surface);border:1px solid var(--border);border-radius:14px;
                  padding:14px;box-shadow:var(--shadow);margin-bottom:14px;}
    .threat-tabs{display:flex;gap:4px;margin-bottom:12px;background:var(--surface2);
                 border-radius:8px;padding:3px;border:1px solid var(--border);}
    .threat-tab{flex:1;padding:5px 10px;border-radius:6px;font-size:11px;font-weight:600;
                cursor:pointer;text-align:center;transition:all 0.15s;border:none;background:transparent;
                color:var(--muted);}
    .threat-tab.active{background:var(--surface);color:var(--text);box-shadow:var(--shadow);}
    .threat-list{display:flex;flex-direction:column;gap:8px;max-height:360px;overflow-y:auto;}
    .threat-list::-webkit-scrollbar{width:4px;}
    .threat-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
    .threat-card{border:1px solid var(--border);border-radius:10px;overflow:hidden;transition:border 0.15s;}
    .threat-card:hover{border-color:var(--indigo-mid);}
    .threat-card.acknowledged{opacity:0.6;}
    .threat-card.dismissed{display:none;}
    .tc-header{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;cursor:pointer;
               background:var(--surface2);}
    .tc-header:hover{background:var(--indigo-light);}
    .tc-left{flex:1;min-width:0;}
    .tc-top{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:4px;}
    .tc-headline{font-size:11px;font-weight:600;line-height:1.4;}
    .tc-meta{font-size:10px;font-family:var(--mono);color:var(--muted);margin-top:2px;}
    .tc-actions{display:flex;gap:6px;flex-shrink:0;align-items:flex-start;}
    .tc-btn{font-size:10px;padding:3px 9px;border-radius:5px;cursor:pointer;font-weight:600;
            border:1px solid;transition:all 0.15s;white-space:nowrap;}
    .tc-btn.ack{color:#059669;border-color:#bbf7d0;background:var(--green-light);}
    .tc-btn.ack:hover{background:#dcfce7;}
    .tc-btn.dis{color:var(--muted);border-color:var(--border);background:var(--surface);}
    .tc-btn.dis:hover{border-color:var(--red);color:var(--red);background:var(--red-light);}
    .tc-btn.reopen{color:var(--indigo);border-color:#c7d2fe;background:var(--indigo-light);}
    .status-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:3px;}
    .status-dot.new{background:var(--red);animation:pulse 2s infinite;}
    .status-dot.acknowledged{background:var(--green);}
    .status-dot.dismissed{background:var(--border);}

    /* MITIGATION EXPAND */
    .tc-body{display:none;padding:10px 12px;border-top:1px solid var(--border);background:var(--surface);}
    .tc-body.open{display:block;}
    .mitigation-label{font-size:10px;font-family:var(--mono);color:var(--muted);font-weight:600;
                      text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;}
    .mitigation-text{font-size:11px;color:var(--text2);line-height:1.6;background:var(--surface2);
                     border-radius:6px;padding:8px 10px;border:1px solid var(--border);}
    .mitigation-meta{display:flex;gap:16px;margin-top:8px;flex-wrap:wrap;}
    .m-meta-item{font-size:10px;font-family:var(--mono);}
    .m-meta-item span{color:var(--muted);}

    /* SUMMARY */
    .summary-title{font-size:12px;font-weight:700;color:var(--indigo);margin-bottom:6px;}
    .summary-box{font-size:12px;line-height:1.8;color:var(--text2);font-family:var(--mono);
                 background:var(--surface2);border-radius:8px;padding:10px 12px;min-height:70px;
                 border:1px solid var(--border);}

    /* ACTIVITY */
    .act-list{display:flex;flex-direction:column;max-height:160px;overflow-y:auto;}
    .act-row{display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid var(--border);}
    .act-row:last-child{border:none;}
    .act-time{font-size:10px;font-family:var(--mono);color:var(--muted);width:44px;flex-shrink:0;padding-top:2px;}
    .act-dot{width:20px;height:20px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;}
    .act-dot.g{background:var(--green-light);}
    .act-dot.r{background:var(--red-light);}
    .act-dot.a{background:var(--indigo-light);}
    .act-text{font-size:11px;color:var(--text2);line-height:1.4;}

    /* SCAN TOAST */
    .scan-toast{display:none;position:fixed;bottom:22px;right:22px;background:var(--surface);
                border:1px solid var(--border);border-radius:12px;padding:10px 16px;font-size:12px;
                font-family:var(--mono);color:var(--indigo);box-shadow:var(--shadow-md);
                z-index:999;align-items:center;gap:8px;}
    .scan-toast.visible{display:flex;}
    .spin{animation:spin 1s linear infinite;display:inline-block;}
    @keyframes spin{to{transform:rotate(360deg);}}
    .progress-bar{height:2px;background:var(--indigo-light);border-radius:1px;margin-top:6px;overflow:hidden;}
    .progress-fill{height:100%;background:var(--indigo);animation:prog 3s ease infinite;}
    @keyframes prog{0%{width:0%;}70%{width:85%;}100%{width:90%;}}

    /* SETTINGS MODAL */
    .modal-overlay{display:none;position:fixed;inset:0;background:rgba(15,23,42,0.45);
                   backdrop-filter:blur(4px);z-index:500;align-items:center;justify-content:center;}
    .modal-overlay.open{display:flex;}
    .modal{background:var(--surface);border-radius:18px;padding:28px;width:440px;max-width:calc(100vw - 32px);
           box-shadow:0 20px 60px rgba(0,0,0,0.18);}
    .modal-title{font-size:16px;font-weight:700;margin-bottom:4px;}
    .modal-sub{font-size:12px;color:var(--text2);margin-bottom:20px;line-height:1.5;}
    .form-label{font-size:11px;font-weight:600;font-family:var(--mono);color:var(--muted);
                text-transform:uppercase;letter-spacing:0.5px;margin-bottom:5px;}
    .form-row{display:flex;gap:8px;margin-bottom:16px;}
    .form-input{flex:1;padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;
                font-size:12px;font-family:var(--mono);outline:none;background:var(--bg);}
    .form-input:focus{border-color:var(--indigo);background:#fff;}
    .form-btn{padding:9px 16px;background:var(--indigo);color:#fff;border:none;border-radius:8px;
              font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;}
    .form-btn:hover{background:var(--indigo-dark);}
    .form-status{font-size:11px;font-family:var(--mono);margin-bottom:14px;min-height:14px;}
    .form-status.ok{color:var(--green);}
    .form-status.err{color:var(--red);}
    .modal-close{float:right;font-size:18px;cursor:pointer;color:var(--muted);background:none;border:none;
                 padding:0;margin:-4px -4px 0 0;line-height:1;}
    .modal-close:hover{color:var(--text);}

    /* EMPTY / ERROR */
    .empty-state{display:flex;flex-direction:column;align-items:center;padding:20px;gap:6px;color:var(--muted);}
    .empty-state-icon{font-size:24px;opacity:0.4;}
    .empty-state-text{font-size:12px;text-align:center;}
    .empty-state-hint{font-size:10px;font-family:var(--mono);opacity:0.7;}
    .error-state{display:flex;align-items:center;gap:6px;padding:10px;background:var(--amber-light);
                 border:1px solid #fde68a;border-radius:8px;font-size:11px;color:#92400e;}

    /* ── UPLOAD SECTION ────────────────────── */
    .upload-zone{border:2px dashed var(--border);border-radius:10px;padding:28px 20px;
                 text-align:center;cursor:pointer;transition:all 0.2s;background:var(--surface2);}
    .upload-zone:hover,.upload-zone.drag-over{border-color:var(--indigo);background:var(--indigo-light);}
    .upload-zone-icon{font-size:30px;margin-bottom:8px;}
    .upload-zone-title{font-size:13px;font-weight:600;color:var(--text2);}
    .upload-zone-hint{font-size:10px;font-family:var(--mono);color:var(--muted);margin-top:4px;}
    .upload-selected{display:none;align-items:center;gap:10px;padding:10px 14px;
                     background:var(--indigo-light);border:1px solid #c7d2fe;border-radius:8px;}
    .upload-log-wrap{display:none;}
    .upload-log-label{font-size:10px;font-weight:600;font-family:var(--mono);color:var(--muted);
                      text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;}
    .upload-log{background:#0f172a;border-radius:8px;padding:12px 14px;font-size:11px;
                font-family:var(--mono);color:#94a3b8;max-height:220px;overflow-y:auto;line-height:1.9;}
    .upload-log::-webkit-scrollbar{width:4px;}
    .upload-log::-webkit-scrollbar-thumb{background:#334155;border-radius:4px;}
    .upload-log .log-red{color:#f87171;}
    .upload-log .log-orange{color:#fb923c;}
    .upload-log .log-yellow{color:#fbbf24;}
    .upload-log .log-green{color:#34d399;}
    .upload-log .log-blue{color:#818cf8;}
    .upload-log .log-dim{color:#475569;}
    .upload-stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;display:none;}

    /* ── AGENTS SECTION ─────────────────────── */
    .agents-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
    @media(max-width:900px){.agents-grid{grid-template-columns:repeat(2,1fr);}}
    @media(max-width:580px){.agents-grid{grid-template-columns:1fr;}}
    .agent-card{border:1px solid var(--border);border-radius:12px;padding:14px;
                background:var(--surface2);transition:border 0.2s,box-shadow 0.2s;}
    .agent-card:hover{border-color:var(--indigo-mid);box-shadow:var(--shadow-md);}
    .agent-card-top{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
    .agent-icon{width:38px;height:38px;border-radius:10px;background:var(--indigo-light);
                display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
    .agent-name{font-size:12px;font-weight:600;line-height:1.3;}
    .agent-type{font-size:10px;font-family:var(--mono);color:var(--muted);}
    .agent-status-badge{font-size:10px;font-weight:600;padding:3px 8px;border-radius:20px;
                        border:1px solid var(--border);white-space:nowrap;margin-left:auto;}
    .agent-status-badge.Active{background:var(--green-light);color:#059669;border-color:#bbf7d0;}
    .agent-status-badge.Idle{background:var(--surface2);color:var(--muted);border-color:var(--border);}
    .agent-status-badge.Warning{background:var(--amber-light);color:#b45309;border-color:#fde68a;}
    .agent-status-badge.Error{background:var(--red-light);color:var(--red);border-color:#fecaca;}
    .agent-metrics{display:flex;gap:12px;margin-bottom:10px;}
    .agent-metric{flex:1;}
    .agent-metric-label{font-size:9px;font-family:var(--mono);color:var(--muted);margin-bottom:3px;}
    .agent-metric-value{font-size:22px;font-weight:800;font-family:var(--mono);}
    .agent-metric-value.risk-low{color:var(--green);}
    .agent-metric-value.risk-med{color:var(--amber);}
    .agent-metric-value.risk-high{color:var(--orange);}
    .agent-metric-value.risk-crit{color:var(--red);}
    .agent-metric-value.tasks{color:var(--indigo);}
    .agent-last{font-size:10px;font-family:var(--mono);color:var(--muted);margin-bottom:10px;}
    .agent-progress-wrap{margin-bottom:10px;}
    .agent-progress-label{display:flex;justify-content:space-between;font-size:9px;font-family:var(--mono);
                          color:var(--muted);margin-bottom:3px;}
    .agent-progress-bar{height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
    .agent-progress-fill{height:100%;border-radius:2px;transition:width 0.4s ease;}
  </style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="tb-left">
    <a href="/" class="home-link"><div class="tb-logo">⚡</div></a>
    <div class="tb-name">Destro</div>
    <div class="tb-badge"><div class="live-dot"></div><span id="status-text">LIVE</span></div>
  </div>
  <div class="tb-right">
    <div id="clock"></div>
    <div class="ai-pill off" id="ai-pill" onclick="openSettings()" title="Configure AI">🤖 <span id="ai-label">No AI Key</span></div>
    <div class="alert-pill hidden" id="alert-pill">⚠ <span id="alert-count">0</span> threats</div>
    <div class="icon-btn" onclick="openSettings()" title="Settings">⚙</div>
    <div class="icon-btn" title="Home" onclick="window.location='/'">🏠</div>
  </div>
</div>

<div class="body-wrap">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sb-icon active" title="Overview"   onclick="navTo('overview',this)">⊞</div>
    <div class="sb-icon"       title="Threats"     onclick="navTo('threats',this)">🛡️</div>
    <div class="sb-sep"></div>
    <div class="sb-icon"       title="Headlines"   onclick="navTo('headlines',this)">📰</div>
    <div class="sb-icon"       title="Activity"    onclick="navTo('activity',this)">≡</div>
    <div class="sb-sep"></div>
    <div class="sb-icon"       title="Upload"      onclick="navTo('upload',this)">⬆</div>
    <div class="sb-icon"       title="Agents"      onclick="navTo('agents',this)">🤖</div>
    <div class="sb-icon" style="margin-top:auto;" title="Settings" onclick="openSettings()">⚙</div>
  </div>

  <div class="main" id="main-scroll">

    <!-- HEADER -->
    <section id="overview">
    <div class="main-header">
      <div>
        <div class="main-title">Threat Overview</div>
        <div class="main-sub" id="last-scan">No scan yet — click Run Scan to start</div>
      </div>
      <div class="header-btns">
        <button class="btn btn-attack" id="attack-btn" onclick="toggleAttack()">⚠ Simulate Attack</button>
        <button class="btn btn-scan"   id="scan-btn"   onclick="triggerScan()">▶ Run Scan</button>
      </div>
    </div>

    <!-- BANNERS -->
    <div class="banner banner-nokey visible" id="nokey-banner">
      <div style="font-size:15px">🤖</div>
      <div>No AI key set — using keyword-based detection.
        <a href="#" onclick="openSettings();return false" style="color:var(--indigo);font-weight:600;text-decoration:none;">
          Configure OpenRouter →
        </a>
      </div>
    </div>
    <div class="banner banner-attack"  id="attack-bar">
      <div style="font-size:15px">🔴</div>
      <div>Attack mode active — malicious headlines injected for demo</div>
    </div>
    <div class="banner banner-inject"  id="inject-banner">
      <div style="font-size:15px">🚨</div>
      <div>
        <div>Prompt injection detected in scraped content</div>
        <div class="banner-payload" id="inject-payload"></div>
      </div>
    </div>
    <div class="banner banner-error"   id="error-banner">
      <div style="font-size:15px">⚠</div>
      <div id="error-text">An error occurred during the last scan.</div>
    </div>

    <!-- STAT CARDS -->
    <div class="stat-row">
      <div class="stat-card">
        <div class="sc-label">TOTAL SCANNED</div>
        <div class="sc-value indigo" id="stat-total">—</div>
        <div class="sc-sub">headlines</div>
      </div>
      <div class="stat-card">
        <div class="sc-label">THREATS FOUND</div>
        <div class="sc-value amber" id="stat-threats">—</div>
        <div class="sc-sub">flagged by AI</div>
      </div>
      <div class="stat-card">
        <div class="sc-label">CRITICAL</div>
        <div class="sc-value red" id="stat-critical">—</div>
        <div class="sc-sub">require immediate action</div>
      </div>
      <div class="stat-card">
        <div class="sc-label">PENDING REVIEW</div>
        <div class="sc-value" id="stat-pending" style="color:var(--text)">—</div>
        <div class="sc-sub">unacknowledged threats</div>
      </div>
    </div>

    <!-- CHARTS -->
    <div class="charts-row">
      <div class="chart-card">
        <div class="chart-title">Severity Breakdown</div>
        <div class="chart-sub">By threat level</div>
        <div class="chart-wrap donut">
          <canvas id="donutChart"></canvas>
          <div class="donut-center">
            <div class="donut-num" id="donut-total">0</div>
            <div class="donut-label">total</div>
          </div>
        </div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Scan History</div>
        <div class="chart-sub">Threats per scan · persisted</div>
        <div class="chart-wrap line"><canvas id="lineChart"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">By Source</div>
        <div class="chart-sub">Headlines per source</div>
        <div class="chart-wrap bar"><canvas id="barChart"></canvas></div>
      </div>
    </div>
    </section>

    <!-- THREAT RESPONSE -->
    <section id="threats">
    <div class="threat-panel">
      <div class="panel-header">
        <div class="panel-title">🛡️ Threat Response</div>
        <div class="panel-meta" id="threat-meta">—</div>
      </div>
      <div class="threat-tabs">
        <button class="threat-tab active" id="tab-new"  onclick="setTab('new')">New</button>
        <button class="threat-tab"        id="tab-ack"  onclick="setTab('ack')">Acknowledged</button>
        <button class="threat-tab"        id="tab-all"  onclick="setTab('all')">All</button>
      </div>
      <div class="threat-list" id="threat-list">
        <div class="empty-state">
          <div class="empty-state-icon">🛡️</div>
          <div class="empty-state-text">No threats to show</div>
          <div class="empty-state-hint">Run a scan to populate this panel</div>
        </div>
      </div>
    </div>
    </section>

    <!-- HEADLINES + SUMMARY -->
    <section id="headlines">
    <div class="content-row">
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">📰 All Headlines</div>
          <div class="panel-meta" id="hl-count">—</div>
        </div>
        <div class="headline-list" id="headline-list">
          <div class="empty-state">
            <div class="empty-state-icon">📡</div>
            <div class="empty-state-text">No headlines yet</div>
            <div class="empty-state-hint">Click "Run Scan" to fetch live data</div>
          </div>
        </div>
      </div>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">🤖 AI Summary</div>
          <div class="panel-meta" id="summary-mode">rule-based</div>
        </div>
        <div class="summary-title" id="summary-title">Waiting for scan...</div>
        <div class="summary-box"  id="summary-box">Run a scan to generate a summary of the current threat landscape.</div>
      </div>
    </div>
    </section>

    <!-- ACTIVITY -->
    <section id="activity">
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">Activity Log</div>
        <div class="panel-meta" id="log-meta" style="cursor:pointer" onclick="clearLog()">clear ✕</div>
      </div>
      <div class="act-list" id="act-list">
        <div class="act-row">
          <div class="act-time">--:--</div>
          <div class="act-dot g">✓</div>
          <div class="act-text">Destro loaded — waiting for first scan</div>
        </div>
      </div>
    </div>
    </section>

    <!-- ═══════════════ UPLOAD SECTION ═══════════════ -->
    <section id="upload">
    <div class="panel" style="margin-bottom:14px;">
      <div class="panel-header">
        <div class="panel-title">⬆ Upload &amp; Analyze</div>
        <div class="panel-meta">CSV · JSON · TXT · max 5 MB</div>
      </div>

      <div style="display:flex;flex-direction:column;gap:12px;">

        <!-- Drop zone -->
        <div class="upload-zone" id="upload-zone"
             onclick="document.getElementById('file-input').click()"
             ondragover="uploadDragOver(event)"
             ondragleave="uploadDragLeave(event)"
             ondrop="uploadDrop(event)">
          <div class="upload-zone-icon">📂</div>
          <div class="upload-zone-title">Click to select or drag &amp; drop a file</div>
          <div class="upload-zone-hint">Supported: .csv · .json · .txt — max 5 MB</div>
          <input type="file" id="file-input" accept=".csv,.json,.txt"
                 style="display:none" onchange="uploadFileSelected()">
        </div>

        <!-- Selected file bar -->
        <div class="upload-selected" id="upload-selected">
          <span style="font-size:20px;">📄</span>
          <div style="flex:1;min-width:0;">
            <div id="upload-filename" style="font-size:12px;font-weight:600;color:var(--text);"></div>
            <div id="upload-filesize" style="font-size:10px;font-family:var(--mono);color:var(--muted);"></div>
          </div>
          <button class="btn btn-scan" id="upload-btn" onclick="doUpload()">⬆ Analyze</button>
          <button class="btn" style="border-color:var(--border);color:var(--muted);background:var(--surface);"
                  onclick="uploadClear()">✕</button>
        </div>

        <!-- Upload stats (hidden until upload) -->
        <div class="upload-stat-row" id="upload-stat-row">
          <div class="stat-card">
            <div class="sc-label">RECORDS</div>
            <div class="sc-value indigo" id="ustat-total">0</div>
            <div class="sc-sub">parsed</div>
          </div>
          <div class="stat-card">
            <div class="sc-label">THREATS</div>
            <div class="sc-value amber" id="ustat-threats">0</div>
            <div class="sc-sub">detected</div>
          </div>
          <div class="stat-card">
            <div class="sc-label">CRITICAL</div>
            <div class="sc-value red" id="ustat-critical">0</div>
            <div class="sc-sub">high priority</div>
          </div>
        </div>

        <!-- Analysis log -->
        <div class="upload-log-wrap" id="upload-log-wrap">
          <div class="upload-log-label">Analysis Results</div>
          <div class="upload-log" id="upload-log"></div>
        </div>

      </div>
    </div>
    </section>

    <!-- ═══════════════ AGENTS SECTION ═══════════════ -->
    <section id="agents">
    <div class="panel" style="margin-bottom:14px;">
      <div class="panel-header">
        <div class="panel-title">🤖 Agents</div>
        <div style="display:flex;align-items:center;gap:10px;">
          <div class="panel-meta" id="agents-meta">Loading...</div>
          <button class="btn" style="font-size:10px;padding:4px 10px;border-color:var(--border);color:var(--text2);"
                  onclick="loadAgents()">↻ Refresh All</button>
        </div>
      </div>
      <div class="agents-grid" id="agents-grid">
        <!-- Skeleton cards while loading -->
        <div class="agent-card" style="opacity:0.4;" id="ag-skel-1"><div class="agent-card-top"><div class="agent-icon">⋯</div><div><div class="agent-name">Loading...</div><div class="agent-type">—</div></div></div></div>
        <div class="agent-card" style="opacity:0.4;" id="ag-skel-2"><div class="agent-card-top"><div class="agent-icon">⋯</div><div><div class="agent-name">Loading...</div><div class="agent-type">—</div></div></div></div>
        <div class="agent-card" style="opacity:0.4;" id="ag-skel-3"><div class="agent-card-top"><div class="agent-icon">⋯</div><div><div class="agent-name">Loading...</div><div class="agent-type">—</div></div></div></div>
      </div>
    </div>
    </section>

  </div><!-- /.main -->
</div><!-- /.body-wrap -->

<!-- SCAN TOAST -->
<div class="scan-toast" id="scan-toast">
  <span class="spin">↻</span>
  <div>
    <div>Scanning &amp; analysing...</div>
    <div class="progress-bar"><div class="progress-fill"></div></div>
  </div>
</div>

<!-- SETTINGS MODAL -->
<div class="modal-overlay" id="modal-overlay" onclick="closeIfBg(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeSettings()">✕</button>
    <div class="modal-title">⚙ Settings</div>
    <div class="modal-sub">Configure your OpenRouter API key to enable AI-powered threat analysis and smarter summaries.</div>
    <div class="form-label">OpenRouter API Key</div>
    <div class="form-row">
      <input type="password" class="form-input" id="modal-key-input" placeholder="sk-or-v1-…" autocomplete="off"/>
      <button class="form-btn" id="modal-key-btn" onclick="modalSaveKey()">Save &amp; Test</button>
    </div>
    <div class="form-status" id="modal-key-status"></div>
    <div style="font-size:11px;color:var(--muted);line-height:1.6;">
      Get a free key at <a href="https://openrouter.ai/keys" target="_blank" style="color:var(--indigo)">openrouter.ai/keys</a>.
      Key is stored in server memory for this session only.
    </div>
  </div>
</div>

<script>

  // ── Clock ─────────────────────────────────
  const tick = () => document.getElementById('clock').textContent =
    new Date().toLocaleTimeString('en-US',{hour12:false});
  setInterval(tick,1000); tick();

  // ── Sidebar nav ───────────────────────────
  function navTo(id, el) {
    document.getElementById(id)?.scrollIntoView({behavior:'smooth'});
    document.querySelectorAll('.sb-icon').forEach(e=>e.classList.remove('active'));
    el?.classList.add('active');
    // Lazy-load section data on first visit
    if (id === 'agents')  loadAgents();
    if (id === 'threats') loadThreats();
  }

  function clearLog() {
    activityLog = []; renderLog();
    addLog('✕','a','Activity log cleared');
  }

  // ── State ─────────────────────────────────
  let attackMode = false;
  let activityLog = [];
  let currentTab = 'new';
  let allThreats = [];

  const loadHistory = () => { try { return JSON.parse(localStorage.getItem('destro_v2_history')||'[]'); } catch { return []; } };
  const saveHistory = h => { try { localStorage.setItem('destro_v2_history', JSON.stringify(h)); } catch {} };
  let scanHistory = loadHistory();

  // ── Charts ────────────────────────────────
  const cDefaults = {
    responsive:true, maintainAspectRatio:false,
    plugins:{ legend:{display:false}, tooltip:{boxPadding:4} }
  };

  const donutChart = new Chart(document.getElementById('donutChart').getContext('2d'), {
    type:'doughnut',
    data:{
      labels:['Critical','High','Medium','Low'],
      datasets:[{
        data:[0,0,0,0],
        backgroundColor:['#ef4444','#f97316','#f59e0b','#10b981'],
        borderColor:'#fff', borderWidth:3
      }]
    },
    options:{...cDefaults, cutout:'72%',
      plugins:{legend:{display:false}, tooltip:{callbacks:{label:c=>` ${c.label}: ${c.parsed}`}}}}
  });

  const lineChart = new Chart(document.getElementById('lineChart').getContext('2d'), {
    type:'line',
    data:{
      labels: scanHistory.map(s=>s.time),
      datasets:[{
        label:'Threats', data: scanHistory.map(s=>s.flagged),
        borderColor:'#6366f1', backgroundColor:'rgba(99,102,241,0.08)',
        borderWidth:2, pointBackgroundColor:'#6366f1', pointRadius:4,
        tension:0.4, fill:true
      }]
    },
    options:{...cDefaults, scales:{
      x:{grid:{display:false}, ticks:{font:{size:10},color:'#94a3b8'}},
      y:{grid:{color:'#f1f5f9'}, ticks:{font:{size:10},color:'#94a3b8',stepSize:1},beginAtZero:true}
    }}
  });

  const barChart = new Chart(document.getElementById('barChart').getContext('2d'), {
    type:'bar',
    data:{labels:[], datasets:[{label:'Headlines', data:[],
      backgroundColor:['rgba(99,102,241,0.7)','rgba(168,85,247,0.7)','rgba(16,185,129,0.7)','rgba(245,158,11,0.7)','rgba(239,68,68,0.7)'],
      borderRadius:5, borderSkipped:false}]},
    options:{...cDefaults, scales:{
      x:{grid:{display:false}, ticks:{font:{size:10},color:'#94a3b8'}},
      y:{grid:{color:'#f1f5f9'}, ticks:{font:{size:10},color:'#94a3b8',stepSize:1},beginAtZero:true}
    }}
  });

  function updateCharts(headlines, flagged, total, threats) {
    document.getElementById('donut-total').textContent = total;
    const critical = threats.filter(t=>t.severity==='CRITICAL').length;
    const high     = threats.filter(t=>t.severity==='HIGH').length;
    const medium   = threats.filter(t=>t.severity==='MEDIUM').length;
    const low      = threats.filter(t=>t.severity==='LOW').length;
    donutChart.data.datasets[0].data = [critical, high, medium, low];
    donutChart.update('active');

    const t = new Date().toLocaleTimeString('en-US',{hour12:false,hour:'2-digit',minute:'2-digit'});
    scanHistory.push({time:t, flagged});
    if (scanHistory.length > 10) scanHistory.shift();
    saveHistory(scanHistory);
    lineChart.data.labels = scanHistory.map(s=>s.time);
    lineChart.data.datasets[0].data = scanHistory.map(s=>s.flagged);
    lineChart.update('active');

    const sources = {};
    (headlines||[]).forEach(h => { const s=h.source||'?'; sources[s]=(sources[s]||0)+1; });
    barChart.data.labels = Object.keys(sources);
    barChart.data.datasets[0].data = Object.values(sources);
    barChart.update('active');
  }

  // ── Severity helpers ──────────────────────
  function sevClass(s) { return {CRITICAL:'sev-CRITICAL',HIGH:'sev-HIGH',MEDIUM:'sev-MEDIUM',LOW:'sev-LOW',NONE:'sev-NONE'}[s]||'sev-NONE'; }
  function sevBarClass(s){ return {CRITICAL:'CRITICAL',HIGH:'HIGH',MEDIUM:'MEDIUM',LOW:'LOW'}[s]||'NONE'; }
  function sevRowClass(s){ return {CRITICAL:'threat-row CRITICAL',HIGH:'threat-row HIGH',MEDIUM:'threat-row MEDIUM',LOW:'threat-row LOW'}[s]||''; }

  // ── Activity log ──────────────────────────
  function addLog(icon, cls, msg) {
    const t = new Date().toLocaleTimeString('en-US',{hour12:false,hour:'2-digit',minute:'2-digit'});
    activityLog.unshift({time:t,icon,cls,msg});
    if (activityLog.length>25) activityLog.pop();
    renderLog();
  }
  function renderLog() {
    const el = document.getElementById('act-list');
    if (!activityLog.length) { el.innerHTML='<div style="font-size:11px;color:var(--muted);padding:10px;text-align:center">No entries</div>'; return; }
    el.innerHTML = activityLog.map(a=>`
      <div class="act-row">
        <div class="act-time">${a.time}</div>
        <div class="act-dot ${a.cls}">${a.icon}</div>
        <div class="act-text">${a.msg}</div>
      </div>`).join('');
    document.getElementById('log-meta').textContent = `${activityLog.length} entries · clear ✕`;
  }

  // ── Threat panel ──────────────────────────
  function setTab(tab) {
    currentTab = tab;
    ['new','ack','all'].forEach(t => {
      document.getElementById('tab-'+t).classList.toggle('active', t===tab);
    });
    renderThreats(allThreats);
  }

  function renderThreats(threats) {
    allThreats = threats;
    const list = document.getElementById('threat-list');
    const newCount  = threats.filter(t=>t.status==='new').length;
    const ackCount  = threats.filter(t=>t.status==='acknowledged').length;
    document.getElementById('threat-meta').textContent =
      `${newCount} new · ${ackCount} acknowledged · ${threats.length} total`;
    document.getElementById('stat-pending').textContent = newCount || '0';

    let filtered = threats;
    if (currentTab === 'new') filtered = threats.filter(t=>t.status==='new');
    if (currentTab === 'ack') filtered = threats.filter(t=>t.status==='acknowledged');

    if (!filtered.length) {
      list.innerHTML = `<div class="empty-state">
        <div class="empty-state-icon">${currentTab==='new'?'✅':'🔍'}</div>
        <div class="empty-state-text">${currentTab==='new'?'No new threats — all reviewed!':'No threats in this tab'}</div>
      </div>`;
      return;
    }

    const order = {CRITICAL:0,HIGH:1,MEDIUM:2,LOW:3,NONE:4};
    filtered.sort((a,b) => (order[a.severity]||4) - (order[b.severity]||4));

    list.innerHTML = filtered.map((t,i) => {
      const key   = esc(t.headline||'').substring(0,80);
      const isNew = t.status === 'new';
      const isAck = t.status === 'acknowledged';
      return `
      <div class="threat-card" id="tc-${i}" data-key="${key}" data-status="${t.status}">
        <div class="tc-header" onclick="toggleExpand(${i})">
          <div class="status-dot ${t.status||'new'}" style="margin-top:6px"></div>
          <div class="tc-left">
            <div class="tc-top">
              <span class="sev ${sevClass(t.severity)}">${t.severity||'NONE'}</span>
              <span style="font-size:10px;font-family:var(--mono);color:var(--muted);background:var(--surface2);
                           padding:1px 6px;border-radius:4px;border:1px solid var(--border)">${esc(t.category||'Other')}</span>
              ${t.cve_ref && t.cve_ref!=='N/A' ? `<span style="font-size:9px;font-family:var(--mono);color:var(--indigo)">${esc(t.cve_ref)}</span>` : ''}
            </div>
            <div class="tc-headline">${esc(t.headline||'')}</div>
            <div class="tc-meta">${esc(t.source||'')} · Affected: ${esc(t.affected||'Unknown')}</div>
          </div>
          <div class="tc-actions" onclick="event.stopPropagation()">
            ${isNew  ? `<button class="tc-btn ack" onclick="threatAction('${key}','acknowledge',${i},'${currentTab}')">✓ Ack</button>` : ''}
            ${isAck  ? `<button class="tc-btn reopen" onclick="threatAction('${key}','reopen',${i},'${currentTab}')">↩ Reopen</button>` : ''}
            ${!isNew && !isAck ? '' : `<button class="tc-btn dis" onclick="threatAction('${key}','dismiss',${i},'${currentTab}')">✕</button>`}
          </div>
        </div>
        <div class="tc-body" id="tb-${i}">
          <div class="mitigation-label">Recommended Action</div>
          <div class="mitigation-text">${esc(t.mitigation || 'No mitigation data available.')}</div>
          <div class="mitigation-meta">
            <div class="m-meta-item"><span>Source: </span>${esc(t.source||'?')}</div>
            <div class="m-meta-item"><span>Category: </span>${esc(t.category||'?')}</div>
            ${t.cve_ref && t.cve_ref!=='N/A' ? `<div class="m-meta-item"><span>CVE: </span>${esc(t.cve_ref)}</div>` : ''}
          </div>
        </div>
      </div>`;
    }).join('');
  }

  function toggleExpand(i) {
    const body = document.getElementById('tb-'+i);
    if (!body) return;
    const isOpen = body.classList.contains('open');
    document.querySelectorAll('.tc-body.open').forEach(el=>el.classList.remove('open'));
    if (!isOpen) body.classList.add('open');
  }

  async function threatAction(key, action, idx, tab) {
    try {
      const res = await fetch('/api/threat-action', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({headline: key, action})
      });
      if (!res.ok) throw new Error('Failed');
      const statusMap = {acknowledge:'acknowledged', dismiss:'dismissed', reopen:'new'};
      const t = allThreats.find(t=>(t.headline||'').substring(0,80)===key);
      if (t) t.status = statusMap[action] || 'new';
      renderThreats(allThreats);
      addLog(action==='acknowledge'?'✓':action==='dismiss'?'✕':'↩',
             action==='acknowledge'?'g':'a',
             `Threat ${action}d: ${key.substring(0,50)}…`);
    } catch(e) { addLog('✗','r','Action failed: '+e.message); }
  }

  // ── Scan flow ─────────────────────────────
  async function triggerScan() {
    const btn = document.getElementById('scan-btn');
    btn.innerHTML = '<span class="spin">↻</span> Scanning...';
    btn.disabled = true;
    document.getElementById('scan-toast').classList.add('visible');
    document.getElementById('status-text').textContent = 'SCANNING';
    document.getElementById('error-banner').classList.remove('visible');
    addLog('↻','a','Scan started — scraping + AI analysis');
    try {
      const res = await fetch('/api/scan',{method:'POST'});
      if (res.status===409) { addLog('⚠','r','Scan already running'); return; }
      pollStatus();
    } catch(e) {
      addLog('✗','r','Failed to start: '+e.message);
    } finally {
      btn.innerHTML = '▶ Run Scan';
      btn.disabled = false;
    }
  }

  async function pollStatus() {
    const iv = setInterval(async () => {
      try {
        const data = await (await fetch('/api/status')).json();
        if (!data.scan_in_progress) {
          clearInterval(iv);
          document.getElementById('scan-toast').classList.remove('visible');
          document.getElementById('status-text').textContent = 'LIVE';
          await loadAll(data);
          addLog('✓','g',`Scan done — ${data.total_scraped} headlines, ${data.flagged_count} threats, ${data.critical_count} critical`);
          if (data.error) showError('Pipeline error: '+data.error);
          // Refresh agents to reflect scan activity
          loadAgents();
        }
      } catch(e) { clearInterval(iv); }
    }, 1800);
  }

  async function loadAll(statusData) {
    updateStatsBar(statusData);
    const [headlines, threats] = await Promise.all([loadHeadlines(), loadThreats()]);
    await loadSummary(statusData.api_key_set);
    updateCharts(headlines, statusData.flagged_count, statusData.total_scraped, threats);
  }

  function updateStatsBar(data) {
    if (data.last_scan_time) document.getElementById('last-scan').textContent = `Last scan at ${data.last_scan_time}`;
    document.getElementById('stat-total').textContent    = data.total_scraped   ?? '—';
    document.getElementById('stat-threats').textContent  = data.flagged_count  ?? '—';
    document.getElementById('stat-critical').textContent = data.critical_count ?? '—';

    document.getElementById('alert-count').textContent = data.flagged_count || 0;
    document.getElementById('alert-pill').classList.toggle('hidden', !data.flagged_count);
    document.getElementById('attack-bar').classList.toggle('visible', !!data.attack_mode);

    const pill = document.getElementById('ai-pill');
    const aiLabel = document.getElementById('ai-label');
    if (data.api_key_set) {
      pill.className = 'ai-pill on';
      aiLabel.textContent = 'AI Active';
      document.getElementById('nokey-banner').classList.remove('visible');
    } else {
      pill.className = 'ai-pill off';
      aiLabel.textContent = 'No AI Key';
      document.getElementById('nokey-banner').classList.add('visible');
    }

    if (data.injection_detected) {
      document.getElementById('inject-banner').classList.add('visible');
      document.getElementById('inject-payload').textContent = data.injection_payload || '';
    } else {
      document.getElementById('inject-banner').classList.remove('visible');
    }
  }

  async function loadHeadlines() {
    const list = document.getElementById('headline-list');
    try {
      const data = await (await fetch('/api/headlines')).json();
      document.getElementById('hl-count').textContent = `${data.total} total`;
      if (!data.headlines?.length) {
        list.innerHTML=`<div class="empty-state"><div class="empty-state-icon">📡</div><div class="empty-state-text">No headlines yet</div></div>`;
        return [];
      }
      list.innerHTML = data.headlines.map(h => {
        const sc = sevBarClass(h.severity);
        return `<div class="hl-row ${h.is_threat ? sevRowClass(h.severity) : ''}">
          <div class="sev-bar ${sc}"></div>
          <div class="hl-body">
            <div class="hl-src">${esc(h.source||'?')}</div>
            <div class="hl-text">${esc(h.headline||'')}</div>
            ${h.category && h.category!=='None' ? `<div class="hl-cat">${esc(h.category)}</div>` : ''}
          </div>
          ${h.severity && h.severity!=='NONE' ? `<span class="sev ${sevClass(h.severity)}">${h.severity}</span>` : ''}
        </div>`;
      }).join('');
      return data.headlines;
    } catch(e) {
      list.innerHTML=`<div class="error-state">⚠ Failed to load — ${esc(e.message)}</div>`;
      return [];
    }
  }

  async function loadThreats() {
    try {
      const data = await (await fetch('/api/threats')).json();
      renderThreats(data.threats || []);
      return data.threats || [];
    } catch(e) {
      document.getElementById('threat-list').innerHTML=`<div class="error-state">⚠ Failed — ${esc(e.message)}</div>`;
      return [];
    }
  }

  async function loadSummary(aiActive) {
    try {
      const data = await (await fetch('/api/summary')).json();
      document.getElementById('summary-title').textContent = data.title || 'Summary';
      document.getElementById('summary-box').textContent   = data.summary || 'No summary.';
      document.getElementById('summary-mode').textContent  = aiActive ? 'AI-powered' : 'rule-based';
    } catch(e) {
      document.getElementById('summary-title').textContent = 'Unavailable';
      document.getElementById('summary-box').innerHTML = `<div class="error-state">⚠ ${esc(e.message)}</div>`;
    }
  }

  async function toggleAttack() {
    const btn = document.getElementById('attack-btn');
    attackMode = !attackMode;
    try {
      const res = await fetch(`/api/attack-mode/${attackMode?'on':'off'}`,{method:'POST'});
      if (!res.ok) throw new Error('HTTP '+res.status);
      btn.textContent = attackMode ? '✕ Disable Attack' : '⚠ Simulate Attack';
      btn.classList.toggle('active', attackMode);
      addLog(attackMode?'⚠':'✓', attackMode?'r':'g',
             attackMode ? 'Attack mode ON — prompt injection headlines injected' : 'Attack mode OFF');
      if (!attackMode) {
        document.getElementById('attack-bar').classList.remove('visible');
        document.getElementById('inject-banner').classList.remove('visible');
      }
    } catch(e) {
      attackMode = !attackMode;
      addLog('✗','r','Failed to toggle: '+e.message);
    }
  }

  function showError(msg) {
    document.getElementById('error-text').textContent = msg;
    document.getElementById('error-banner').classList.add('visible');
    setTimeout(()=>document.getElementById('error-banner').classList.remove('visible'), 8000);
  }

  // ── Settings modal ────────────────────────
  function openSettings() {
    document.getElementById('modal-overlay').classList.add('open');
    document.getElementById('modal-key-input').focus();
  }
  function closeSettings() { document.getElementById('modal-overlay').classList.remove('open'); }
  function closeIfBg(e) { if (e.target===document.getElementById('modal-overlay')) closeSettings(); }

  async function modalSaveKey() {
    const input  = document.getElementById('modal-key-input');
    const btn    = document.getElementById('modal-key-btn');
    const status = document.getElementById('modal-key-status');
    const key = input.value.trim();
    if (!key) { setModalStatus('err','Please enter a key.'); return; }
    btn.disabled = true; btn.textContent = 'Testing…';
    setModalStatus('','Saving…');
    try {
      await fetch('/api/set-key',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({key})});
      const test = await (await fetch('/api/test-key',{method:'POST'})).json();
      if (test.ok) {
        setModalStatus('ok','✓ Key saved and verified — AI analysis enabled');
        document.getElementById('ai-pill').className = 'ai-pill on';
        document.getElementById('ai-label').textContent = 'AI Active';
        document.getElementById('nokey-banner').classList.remove('visible');
        addLog('🔑','g','OpenRouter API key configured — AI analysis enabled');
        setTimeout(closeSettings, 1600);
      } else {
        setModalStatus('err','✗ Saved but test failed: '+(test.error||'unknown'));
      }
    } catch(e) { setModalStatus('err','✗ Error: '+e.message); }
    finally { btn.disabled=false; btn.textContent='Save & Test'; }
  }

  function setModalStatus(cls, msg) {
    const el = document.getElementById('modal-key-status');
    el.className = 'form-status'+(cls?' '+cls:'');
    el.textContent = msg;
  }

  document.getElementById('modal-key-input').addEventListener('keydown', e => { if(e.key==='Enter') modalSaveKey(); });
  document.addEventListener('keydown', e => { if(e.key==='Escape') closeSettings(); });

  // ── XSS helper ───────────────────────────
  function esc(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ═══════════════════════════════════════════
  //  UPLOAD
  // ═══════════════════════════════════════════
  let _uploadFile = null;

  function uploadDragOver(e) {
    e.preventDefault();
    document.getElementById('upload-zone').classList.add('drag-over');
  }
  function uploadDragLeave(e) {
    document.getElementById('upload-zone').classList.remove('drag-over');
  }
  function uploadDrop(e) {
    e.preventDefault();
    uploadDragLeave(e);
    const file = e.dataTransfer?.files?.[0];
    if (file) _setUploadFile(file);
  }
  function uploadFileSelected() {
    const input = document.getElementById('file-input');
    if (input.files?.[0]) _setUploadFile(input.files[0]);
  }
  function _setUploadFile(file) {
    _uploadFile = file;
    document.getElementById('upload-filename').textContent = file.name;
    document.getElementById('upload-filesize').textContent = (file.size / 1024).toFixed(1) + ' KB';
    document.getElementById('upload-selected').style.display = 'flex';
    document.getElementById('upload-log-wrap').style.display = 'none';
    document.getElementById('upload-stat-row').style.display = 'none';
  }
  function uploadClear() {
    _uploadFile = null;
    document.getElementById('upload-selected').style.display = 'none';
    document.getElementById('upload-log-wrap').style.display = 'none';
    document.getElementById('upload-stat-row').style.display = 'none';
    document.getElementById('file-input').value = '';
  }

  async function doUpload() {
    if (!_uploadFile) return;
    const btn = document.getElementById('upload-btn');
    btn.innerHTML = '<span class="spin">↻</span> Analyzing...';
    btn.disabled = true;

    try {
      const fd = new FormData();
      fd.append('file', _uploadFile);
      const res  = await fetch('/api/upload', {method:'POST', body: fd});
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Upload failed');

      // Render log with color coding
      const logEl  = document.getElementById('upload-log');
      const lines  = data.log || [];
      logEl.innerHTML = lines.map(l => {
        let cls = '';
        if (l.startsWith('🔴') || l.includes('CRITICAL')) cls = 'log-red';
        else if (l.startsWith('🟠') || l.includes('HIGH')) cls = 'log-orange';
        else if (l.startsWith('🟡') || l.includes('MEDIUM')) cls = 'log-yellow';
        else if (l.startsWith('✅') || l.startsWith('✓'))   cls = 'log-green';
        else if (l.startsWith('📂') || l.startsWith('📊') || l.startsWith('📁')) cls = 'log-blue';
        else if (l.startsWith('─'))                          cls = 'log-dim';
        return `<div class="${cls}">${esc(l)}</div>`;
      }).join('');

      document.getElementById('upload-log-wrap').style.display = 'block';

      // Show stats
      document.getElementById('ustat-total').textContent    = data.total    ?? 0;
      document.getElementById('ustat-threats').textContent  = data.threats  ?? 0;
      document.getElementById('ustat-critical').textContent = data.critical ?? 0;
      document.getElementById('upload-stat-row').style.display = 'grid';

      addLog('⬆','g',`Uploaded ${data.filename} — ${data.total} records, ${data.threats} threats`);
    } catch(e) {
      const logEl = document.getElementById('upload-log');
      logEl.innerHTML = `<div class="log-red">✗ Error: ${esc(e.message)}</div>`;
      document.getElementById('upload-log-wrap').style.display = 'block';
      addLog('✗','r','Upload failed: '+e.message);
    } finally {
      btn.innerHTML = '⬆ Analyze';
      btn.disabled = false;
    }
  }


  // ═══════════════════════════════════════════
  //  AGENTS
  // ═══════════════════════════════════════════
  function _riskClass(r) {
    if (r >= 70) return 'risk-crit';
    if (r >= 40) return 'risk-high';
    if (r >= 20) return 'risk-med';
    return 'risk-low';
  }
  function _riskColor(r) {
    if (r >= 70) return 'var(--red)';
    if (r >= 40) return 'var(--orange)';
    if (r >= 20) return 'var(--amber)';
    return 'var(--green)';
  }

  async function loadAgents() {
    try {
      const data   = await (await fetch('/api/agents')).json();
      const agents = data.agents || [];
      document.getElementById('agents-meta').textContent = `${agents.length} agents registered`;
      const grid = document.getElementById('agents-grid');

      grid.innerHTML = agents.map(a => {
        const riskPct = Math.min(a.risk_score, 99);
        return `
        <div class="agent-card">
          <div class="agent-card-top">
            <div class="agent-icon">${a.icon || '🤖'}</div>
            <div style="flex:1;min-width:0;">
              <div class="agent-name">${esc(a.name)}</div>
              <div class="agent-type">${esc(a.type)}</div>
            </div>
            <div class="agent-status-badge ${esc(a.status)}">${esc(a.status)}</div>
          </div>
          <div class="agent-metrics">
            <div class="agent-metric">
              <div class="agent-metric-label">RISK SCORE</div>
              <div class="agent-metric-value ${_riskClass(a.risk_score)}">${a.risk_score}</div>
            </div>
            <div class="agent-metric">
              <div class="agent-metric-label">TASKS DONE</div>
              <div class="agent-metric-value tasks">${a.tasks_completed}</div>
            </div>
          </div>
          <div class="agent-progress-wrap">
            <div class="agent-progress-label">
              <span>Risk level</span><span>${riskPct}%</span>
            </div>
            <div class="agent-progress-bar">
              <div class="agent-progress-fill"
                   style="width:${riskPct}%;background:${_riskColor(a.risk_score)};"></div>
            </div>
          </div>
          <div class="agent-last">Last activity: ${esc(a.last_activity)}</div>
          <button class="btn btn-scan"
                  style="width:100%;justify-content:center;font-size:11px;padding:6px 10px;"
                  onclick="updateAgent(${a.id}, this)">↻ Update Status</button>
        </div>`;
      }).join('');
    } catch(e) {
      document.getElementById('agents-grid').innerHTML =
        `<div class="error-state" style="grid-column:1/-1">⚠ Failed to load agents — ${esc(e.message)}</div>`;
    }
  }

  async function updateAgent(id, btn) {
    const orig = btn.innerHTML;
    btn.innerHTML = '<span class="spin">↻</span>';
    btn.disabled = true;
    try {
      const res  = await fetch(`/api/agents/${id}/update`, {method:'POST'});
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Update failed');
      addLog('↻','a',`Agent "${data.name}" refreshed — status: ${data.status}, risk: ${data.risk_score}`);
      await loadAgents();
    } catch(e) {
      addLog('✗','r','Agent update failed: '+e.message);
      btn.innerHTML = orig;
      btn.disabled = false;
    }
  }


  // ── Auto-refresh every 30s ────────────────
  setInterval(async () => {
    try {
      const data = await (await fetch('/api/status')).json();
      if (!data.scan_in_progress && data.last_scan_time) loadAll(data);
    } catch(e) {}
  }, 30000);

  // ── Initial load ──────────────────────────
  (async () => {
    try {
      const data = await (await fetch('/api/status')).json();
      updateStatsBar(data);
      if (data.last_scan_time) {
        await loadHeadlines();
        await loadThreats();
        await loadSummary(data.api_key_set);
      }
      addLog('⚡','g','Destro ready');
    } catch(e) { addLog('✗','r','Could not reach server'); }
    // Always load agents on init
    await loadAgents();
  })();
</script>
</body>
</html>
