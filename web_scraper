# ── HackerNews Algolia API ────────────────────────────────────────────────────
_HN_API_URL = (
    "https://hn.algolia.com/api/v1/search"
    "?tags=front_page&hitsPerPage=15"
)
_TIMEOUT_S = 10

# Security-related keywords to filter from HN front page
_SECURITY_KEYWORDS = {
    "vulnerability", "hack", "breach", "malware", "ransomware", "exploit",
    "phishing", "zero-day", "cve", "security", "attack", "threat", "patch",
    "cyber", "encryption", "leak", "backdoor", "botnet", "ddos", "spyware",
    "privacy", "surveillance", "authentication", "firewall", "intrusion",
}


def _fetch_hn_headlines() -> list:
    """
    Fetch front-page stories from HackerNews via the Algolia search API.
    Returns a list of headline dicts, filtered to security-relevant stories.
    Falls back to an empty list on any network error.
    """
    try:
        req = urllib.request.Request(
            _HN_API_URL,
            headers={"User-Agent": "SentinelAI/1.0 security-dashboard"},
        )
        with urllib.request.urlopen(req, timeout=_TIMEOUT_S) as resp:
            data  = json.loads(resp.read().decode())
            hits  = data.get("hits", [])
            items = []
            for h in hits:
                title = (h.get("title") or "").strip()
                if not title:
                    continue
                # Only keep security-relevant stories
                lower = title.lower()
                if any(kw in lower for kw in _SECURITY_KEYWORDS):
                    items.append({
                        "headline":     title,
                        "source":       "HackerNews",
                        "attack_signal": False,
                    })
            logger.info("Fetched %d security headlines from HackerNews", len(items))
            return items
    except Exception as exc:
        logger.warning("HN fetch failed (%s) — using static fallback", exc)
        return []


def run_scraper() -> list:
    """
    Main scraper entry point.
    - Attack mode: returns injected attack headlines + a few safe ones.
    - Normal mode: fetches live headlines; falls back to static data if empty.
    """
    if attack_state.ATTACK_MODE:
        attack_state.set_attack_detected(True)
        logger.warning("Attack mode active — returning simulated malicious headlines")
        return _ATTACK_HEADLINES + _SAFE_HEADLINES_STATIC[:3]

    live = _fetch_hn_headlines()
    if live:
        return live

    # Network unavailable or no security stories found — use static set
    logger.info("Using static fallback headlines")
    return _SAFE_HEADLINES_STATIC
