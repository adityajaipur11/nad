# ─────────────────────────────────────────────
# summarizing_agent/summarizer.py
# AI summary via OpenRouter. Accepts api_key as constructor arg
# so the key can be set at runtime from the UI.
# ─────────────────────────────────────────────

import json, time, logging, urllib.request, urllib.error

logger = logging.getLogger(__name__)

_MAX_RETRIES   = 3
_RETRY_DELAY_S = 2


class SummarizingAgent:
    def __init__(self, api_key: str = "", base_url: str = "https://openrouter.ai/api/v1",
                 model: str = "openai/gpt-4o-mini"):
        self.api_key  = api_key
        self.base_url = base_url
        self.model    = model

    def generate_summary(self, headlines: list) -> dict:
        if not headlines:
            return {"summary_paragraph": "No headlines to summarize.", "short_description": "No data"}

        total   = len(headlines)
        flagged = sum(1 for h in headlines if h.get("is_threat") or h.get("attack_signal"))
        critical= sum(1 for h in headlines if h.get("severity") == "CRITICAL")

        if not self.api_key:
            logger.warning("No API key — using rule-based summary")
            return self._rule_summary(headlines, total, flagged, critical)

        # Build a richer prompt using AI-enriched fields
        lines = []
        for h in headlines:
            sev = h.get("severity", "NONE")
            cat = h.get("category", "")
            lines.append(f"[{sev}/{cat}] {h.get('headline','')}")
        headline_text = "\n".join(lines)

        prompt = (
            f"You are a senior cybersecurity analyst. Summarize the following {total} headlines "
            f"in 3–4 sentences. Focus on the {flagged} threats ({critical} critical). "
            f"Mention the most urgent actions organisations should take.\n\n{headline_text}"
        )
        return self._call_with_retry(prompt, total, flagged, critical, headlines)

    def _call_with_retry(self, prompt, total, flagged, critical, headlines):
        payload = json.dumps({
            "model":    self.model,
            "messages": [{"role": "user", "content": prompt}],
        }).encode("utf-8")
        last_err = None
        for attempt in range(1, _MAX_RETRIES + 1):
            try:
                req = urllib.request.Request(
                    f"{self.base_url}/chat/completions", data=payload,
                    headers={"Authorization": f"Bearer {self.api_key}",
                             "Content-Type": "application/json"},
                )
                with urllib.request.urlopen(req, timeout=30) as resp:
                    result = json.loads(resp.read().decode())
                    text   = result["choices"][0]["message"]["content"]
                    logger.info("AI summary generated")
                    return {
                        "summary_paragraph": text,
                        "short_description": f"AI Threat Report — {total} analysed, {flagged} threats, {critical} critical",
                    }
            except urllib.error.HTTPError as e:
                last_err = e
                if 400 <= e.code < 500: break
            except Exception as e:
                last_err = e
            if attempt < _MAX_RETRIES:
                time.sleep(_RETRY_DELAY_S)

        logger.error("Summary API failed: %s", last_err)
        return self._rule_summary(None, total, flagged, critical, headlines)

    @staticmethod
    def _rule_summary(_, total, flagged, critical, headlines=None):
        cats = {}
        for h in (headlines or []):
            c = h.get("category","Other")
            if c and c != "None": cats[c] = cats.get(c,0)+1
        top = sorted(cats.items(), key=lambda x:-x[1])[:3]
        top_str = ", ".join(f"{k} ({v})" for k,v in top) if top else "various categories"
        return {
            "summary_paragraph": (
                f"Scanned {total} cybersecurity headlines. {flagged} identified as threats, "
                f"including {critical} critical-severity items. "
                f"Primary threat categories: {top_str}. "
                "Set an OpenRouter API key in Settings to enable AI-generated analysis."
            ),
            "short_description": f"Rule-based Report — {total} scanned, {flagged} threats, {critical} critical",
        }
